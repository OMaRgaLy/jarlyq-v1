# Backend configuration
APP_ENV=development
HTTP_PORT=8080
APP_BASE_URL=http://localhost:3000
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Jarlyq <no-reply@example.com>
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
RATE_LIMIT_PER_MIN=180
CORS_ORIGINS=http://localhost:3000
CSRF_COOKIE_NAME=csrf_token
CSRF_COOKIE_DOMAIN=localhost
SWAGGER_ENABLED=true
# Admin panel — email of the admin user (must register first)
ADMIN_EMAIL=your-email@example.com

# Database configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=jarlyq
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}?sslmode=disable

# Frontend configuration
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Used by Next.js rewrites (server-side), defaults to VPS IP if not set
BACKEND_URL=http://localhost:8080

# Domain (for SSL/production)
DOMAIN=jarlyq.com
